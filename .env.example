# Copy this file to .env and fill in your values
# NEVER commit your .env file to git

# ── Database ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/EduAdapt

# ── Admin Seed ────────────────────────────────────────────────────────────────
ADMIN_NAME=Admin User
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=ChangeMe@2026!

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5001
NODE_ENV=development

# ── JWT (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))") ──
JWT_SECRET=replace_with_64_char_hex_string

# ── CORS (comma-separated list of allowed origins, optional) ──────────────────
CLIENT_URL=http://localhost:3000

# ── Cloudinary ────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── AssemblyAI (video transcription) ─────────────────────────────────────────
ASSEMBLYAI_API_KEY=your_assemblyai_key

# ── Anthropic (chatbot) ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Email (Gmail App Password recommended) ────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your_gmail@gmail.com
MAIL_PASS=your_app_password_here
MAIL_FROM=EduAdapt <your_gmail@gmail.com>

# ── App URL (used in email links) ─────────────────────────────────────────────
APP_URL=http://localhost:5001

# ── Fapshi Mobile Money (https://fapshi.com) ──────────────────────────────────
FAPSHI_API_USER=your_fapshi_api_user
FAPSHI_API_KEY=your_fapshi_api_key
FAPSHI_BASE_URL=https://sandbox.fapshi.com
